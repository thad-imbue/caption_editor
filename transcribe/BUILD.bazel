# Cross-language CLI parity tests. The Rust binaries are wired as `data`
# so Bazel keeps them rebuilt and on disk, but TRANSCRIBE_RS_BIN /
# EMBED_RS_BIN are NOT injected by Bazel — the tests `pytest.skip` when
# the vars are unset, so default `bazel test //...` no-ops these (the
# binaries need network access to pull HF models, which the Bazel
# sandbox blocks). Trigger manually:
#
#   bazel build //transcribe_rs/transcribe-rs //transcribe_rs/embed-rs
#   TRANSCRIBE_RS_BIN=$(bazel info bazel-bin)/transcribe_rs/transcribe-rs/transcribe-rs \
#   EMBED_RS_BIN=$(bazel info bazel-bin)/transcribe_rs/embed-rs/embed-rs \
#   bazel test //transcribe:transcribe_rs_parity_test \
#     --test_env=TRANSCRIBE_RS_BIN --test_env=EMBED_RS_BIN \
#     --test_output=streamed
transcribe_pytest(
    name = "transcribe_rs_parity_test",
    test_file = "transcribe_rs_parity_test.py",
    data = _HEAVY_TEST_DATA + [
        "//transcribe_rs/transcribe-rs:transcribe-rs",
        "//transcribe_rs/embed-rs:embed-rs",
    ],
    deps = _CHEAP_TEST_DEPS,
    # `manual` keeps default `bazel test //...` from picking them up
    # even on a host that happens to have the env vars exported.
    tags = _HEAVY_TAGS + ["requires-network", "manual"],
)

# Integration test for the released Rust ASR binaries. Downloads
# transcribe-rs-v${APP_VERSION}-darwin-arm64 + embed-rs-v${APP_VERSION}-darwin-arm64
# from https://github.com/<repo>/releases/download/v${APP_VERSION}/ and
# runs them end-to-end. APP_VERSION is read from electron/constants.ts
# at test time (the same source the GHA workflow uses to name the
# uploaded artifacts), so a checkout at v1.6.1 exercises the v1.6.1
# release.
#
# Skips automatically if (a) the host isn't darwin-arm64, or (b) the
# release artifact returns 404 (release for this version not published
# yet — useful when developing the release flow itself).
#
# Tagged `manual` so default `bazel test //...` skips it; `requires-network`
# documents the dependency. Trigger:
#
#   bazel test //transcribe:released_rust_asr_test --test_output=streamed
transcribe_pytest(
    name = "released_rust_asr_test",
    test_file = "released_rust_asr_test.py",
    # The test reads electron/constants.ts to figure out which release
    # tag to download from. Pull it into runfiles via the existing
    # exports_files declaration at //:BUILD.bazel.
    data = _HEAVY_TEST_DATA + ["//:electron/constants.ts"],
    deps = _CHEAP_TEST_DEPS,
    tags = _HEAVY_TAGS + ["requires-network", "manual"],
)
