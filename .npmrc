# Ensure package-lock.json is created
package-lock=true

# Pin top-level deps exactly so `package.json` always reflects the
# version that's actually installed. Without this, npm install
# prepends `^` and `npm update` can silently move versions inside the
# caret range — the only diff being thousands of lines of
# `package-lock.json`. Mirroring the Python flow (uv pins exact in
# uv.lock; pyproject.toml carries the loose constraint), every dep
# bump now shows up as a one-line edit in `package.json`.
save-exact=true

# typescript-eslint has peer dep conflicts with its own sub-packages;
# use legacy resolution to avoid blocking installs.
legacy-peer-deps=true

# Aspect rules_js uses pnpm's strict (non-hoisted) `node_modules`
# layout. @vue/test-utils and a few other transitive packages reach
# for peer deps (`@vue/compiler-dom`, ...) via bare specifier resolution
# that only succeeds when those packages are hoisted to the top-level
# `node_modules/`. `public-hoist-pattern[]=*` flattens enough of the
# tree to match npm/yarn semantics — needed for the Bazel-linked tree
# to satisfy vitest + @vue/test-utils at runtime. Costs only graph
# bookkeeping, not correctness: hoisted packages are still resolved
# via the lockfile, just promoted to the public dir for require()
# lookups.
public-hoist-pattern[]=*
